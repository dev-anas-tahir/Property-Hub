{
  "scripts": {
    "build-css": "tailwindcss -i ./frontend/src/input.css -o ./static/dist/output.css --watch",
    "build-css-prod": "tailwindcss -i ./frontend/src/input.css -o ./static/dist/output.css --minify",
    "build-js": "esbuild frontend/src/chat-client.js --outfile=static/dist/chat-client.js --minify",
    "watch-js": "esbuild frontend/src/chat-client.js --outfile=static/dist/chat-client.js --watch",
    "copy-vendor": "mkdir -p static/vendor && cp node_modules/alpinejs/dist/cdn.min.js static/vendor/alpinejs.min.js && cp node_modules/htmx.org/dist/htmx.min.js static/vendor/htmx.min.js",
    "build": "npm run build-css-prod && npm run build-js && npm run copy-vendor",
    "format": "prettier --write \"frontend/**/*.js\"",
    "format:check": "prettier --check \"frontend/**/*.js\""
  },
  "dependencies": {
    "alpinejs": "^3.13.3",
    "htmx.org": "^1.9.10"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "daisyui": "^4.6.0",
    "esbuild": "^0.20.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.0"
  }
}
